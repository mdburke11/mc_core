# ==================================================
# Simulated annealing
# ==================================================

runMode = anneal

numSamples = 1000
thermSweeps = 0
sweepsPerBlock = 10
measInterval = 1
checkpointInterval = 100
numBins = 20

resume = false

outname = anneal_output.h5
checkpointFile = anneal_checkpoint.h5

# annealing schedule

T0 = 5.0
Tf = 0.5
NT = 64
T_mode = linear
annealDirection = cooling

model = Ising2D

L = 32
T = 5.0
J = 1.0

seed = 12345
init = random
